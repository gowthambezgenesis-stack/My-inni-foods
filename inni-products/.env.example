# inni Products — Frontend environment template
# Copy this file to `.env` and adjust values for your machine:
#   cp .env.example .env
#
# Only variables prefixed with VITE_ are exposed to the browser.
# Restart the Vite dev server after any change.

# Django REST API base URL (must match backend CORS + runserver host/port).
# Local default: backend runs on port 8000 with routes under /api/
VITE_API_BASE_URL=http://localhost:8000/api

# Optional: set in CI/production build (e.g. https://api.yourdomain.com/api)
# VITE_API_BASE_URL=https://api.example.com/api
