SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=inni_db
DB_USER=postgres
DB_PASSWORD=your-postgres-password
DB_HOST=localhost
DB_PORT=5432

# Razorpay (get keys from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret-key
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SMTP — required for Super Admin OTP login (Gmail: use an App Password, not your normal password)
# https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=your-gmail@gmail.com

# Optional: print OTP emails to the console instead of sending (local dev only)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# New order admin notifications
ORDER_NOTIFICATIONS_ENABLED=True
FRONTEND_BASE_URL=http://localhost:3000
# Customer order-success emails use the same ORDER_NOTIFICATIONS_ENABLED + SMTP settings

# Twilio WhatsApp — customer order confirmation after payment (optional)
# Sandbox: join your phone in Twilio Console → Messaging → Try WhatsApp
# API_PUBLIC_BASE_URL: public HTTPS URL so Twilio can attach invoice PDF (e.g. ngrok tunnel to :8000)
WHATSAPP_NOTIFICATIONS_ENABLED=False
API_PUBLIC_BASE_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# OpenAPI / Swagger UI (enabled by default when DEBUG=True)
SWAGGER_ENABLED=True

# Meilisearch — typo-tolerant admin order search (run: meilisearch --master-key=devMasterKey)
# Then: python manage.py sync_meilisearch_orders
MEILISEARCH_URL=http://127.0.0.1:7700
MEILISEARCH_API_KEY=devMasterKey

